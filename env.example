# InsForge
NEXT_PUBLIC_INSFORGE_URL=https://your-appkey.us-east.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# App URL (used to build absolute webhook/callback URLs)
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ─── Payment provider ──────────────────────────────────────────
# Set to "stripe" or "redsys" depending on which gateway you use.
PAYMENT_PROVIDER=stripe

# ─── Stripe ────────────────────────────────────────────────────
# From Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Safe to expose in the browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Webhook endpoint to register in Stripe Dashboard → Webhooks:
#   https://yourdomain.com/api/webhooks/stripe
# Events to listen: checkout.session.completed, payment_intent.payment_failed, charge.refunded

# ─── Redsys ────────────────────────────────────────────────────
# Credentials provided by your bank or Redsys directly
REDSYS_MERCHANT_CODE=999008881
REDSYS_TERMINAL=1
# SHA-256 key from the Redsys admin panel
REDSYS_SECRET_KEY=sq7HjrUOBfKmC576ILgskD5srU870gJ7
# "test" or "live"
REDSYS_ENVIRONMENT=test

# Notification URL to configure in Redsys (DS_MERCHANT_MERCHANTURL):
#   https://yourdomain.com/api/webhooks/redsys
